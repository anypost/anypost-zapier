{
  "name": "anypost-zapier",
  "version": "1.0.0",
  "private": true,
  "description": "Anypost integration for the Zapier Platform (CLI app).",
  "main": "index.js",
  "engines": {
    "node": ">=20",
    "npm": ">=9"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "npm run build && jest",
    "validate": "npm run build && zapier-platform validate",
    "push": "npm run build && zapier-platform push",
    "_zapier-build": "npm run build"
  },
  "dependencies": {
    "zapier-platform-core": "19.0.0"
  },
  "overrides": {
    "form-data": "^4.0.6"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.3",
    "zapier-platform-cli": "19.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/test/**/*.test.ts"
    ]
  }
}
